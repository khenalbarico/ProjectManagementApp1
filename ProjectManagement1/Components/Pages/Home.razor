@page "/"
@inject IAppServices AppServices
@inject IAppAuthentication AppAuthentication
@inject NavigationManager Nav

<PageTitle>Project Management</PageTitle>

<div class="pm-dashboard">

    @if (_isLoading)
    {
        <div class="pm-loading">
            <div class="pm-spinner"></div>
            <span>Loading workspace...</span>
        </div>
    }
    else
    {
        <header class="pm-header">
            <div class="pm-header-left">
                <img src="@_manager.ImagePath"
                     alt="@_manager.DisplayName"
                     class="pm-logo-mark" />
                <div>
                    <h1 class="pm-title">@_manager.Title</h1>
                    <p class="pm-subtitle">Project Management Dashboard</p>
                </div>
            </div>
            <div class="pm-header-right">
                <div class="pm-header-stats">
                    <div class="pm-stat">
                        <span class="pm-stat-value">@_projects.Count</span>
                        <span class="pm-stat-label">Projects</span>
                    </div>
                    <div class="pm-stat-divider"></div>
                    <div class="pm-stat">
                        <span class="pm-stat-value">@VisibleDevelopers.Count</span>
                        <span class="pm-stat-label">Developers</span>
                    </div>
                    <div class="pm-stat-divider"></div>
                    <div class="pm-stat">
                        <span class="pm-stat-value">@VisibleWorkItems.Count</span>
                        <span class="pm-stat-label">Work Items</span>
                    </div>
                </div>
                <button class="pm-signout-btn" @onclick="HandleSignOut">Sign Out</button>
            </div>
        </header>

        <div class="pm-grid">

            <section class="pm-card">
                <div class="pm-card-header">
                    <div class="pm-card-title-row">
                        <span class="pm-card-icon pm-card-icon--projects">◈</span>
                        <h2 class="pm-card-title">Projects</h2>
                        <span class="pm-badge">@FilteredProjects.Count</span>
                    </div>
                    <div class="pm-search-row">
                        <input class="pm-search-input" placeholder="Search by title..." @bind="_projSearch" @bind:event="oninput" />
                        <button class="pm-sort-btn @(_projSortAsc ? "pm-sort-btn--asc" : "pm-sort-btn--desc")" @onclick="() => _projSortAsc = !_projSortAsc" title="Sort A-Z / Z-A">
                            ⇅
                        </button>
                    </div>
                    <div class="pm-filter-row">
                        <button class="pm-filter-chip @(_projActivityFilter == null ? "pm-filter-chip--active" : "")" @onclick='() => _projActivityFilter = null'>All</button>
                        <button class="pm-filter-chip @(_projActivityFilter == ProjectActivityStatus.HighActivity ? "pm-filter-chip--active" : "")" @onclick='() => ToggleProjActivityFilter(ProjectActivityStatus.HighActivity)'>High</button>
                        <button class="pm-filter-chip @(_projActivityFilter == ProjectActivityStatus.ModerateActivity ? "pm-filter-chip--active" : "")" @onclick='() => ToggleProjActivityFilter(ProjectActivityStatus.ModerateActivity)'>Moderate</button>
                        <button class="pm-filter-chip @(_projActivityFilter == ProjectActivityStatus.LowActivity ? "pm-filter-chip--active" : "")" @onclick='() => ToggleProjActivityFilter(ProjectActivityStatus.LowActivity)'>Low</button>
                        <span class="pm-filter-divider"></span>
                        <button class="pm-filter-chip @(_projPriorityFilter == null ? "pm-filter-chip--active" : "")" @onclick='() => _projPriorityFilter = null'>All</button>
                        <button class="pm-filter-chip @(_projPriorityFilter == ProjectPriorityStatus.Priority ? "pm-filter-chip--active" : "")" @onclick='() => ToggleProjPriorityFilter(ProjectPriorityStatus.Priority)'>Priority</button>
                        <button class="pm-filter-chip @(_projPriorityFilter == ProjectPriorityStatus.NotPriority ? "pm-filter-chip--active" : "")" @onclick='() => ToggleProjPriorityFilter(ProjectPriorityStatus.NotPriority)'>Not Priority</button>
                    </div>
                </div>
                <div class="pm-card-body">
                    @if (!FilteredProjects.Any())
                    {
                        <div class="pm-empty">
                            <span class="pm-empty-icon">◈</span>
                            <p>No projects match filters.</p>
                        </div>
                    }
                    else
                    {
                        <div class="pm-list">
                            @foreach (var project in FilteredProjects)
                            {
                                <div class="pm-list-item pm-list-item--clickable" @onclick="() => _detailModal.OpenProject(project)">
                                    <div class="pm-list-item-accent pm-list-item-accent--projects"></div>
                                    <div class="pm-list-item-content">
                                        <span class="pm-item-name">@project.Title</span>
                                        <span class="pm-item-sub">@project.KeyPerson</span>
                                    </div>
                                    <div class="pm-item-pills">
                                        <span class="pm-pill pm-pill--priority-@project.Priority.ToString().ToLower()">@FormatEnum(project.Priority)</span>
                                        <span class="pm-pill pm-pill--activity-@GetActivityClass(project.Activity)">@FormatEnum(project.Activity)</span>
                                    </div>
                                    <span class="pm-list-item-arrow">›</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="pm-card">
                <div class="pm-card-header">
                    <div class="pm-card-title-row">
                        <span class="pm-card-icon pm-card-icon--developers">⬡</span>
                        <h2 class="pm-card-title">Developers</h2>
                        <span class="pm-badge">@FilteredDevelopers.Count</span>
                    </div>
                    <div class="pm-search-row">
                        <input class="pm-search-input" placeholder="Search by name..." @bind="_devSearch" @bind:event="oninput" />
                        <button class="pm-sort-btn @(_devSortAsc ? "pm-sort-btn--asc" : "pm-sort-btn--desc")" @onclick="() => _devSortAsc = !_devSortAsc" title="Sort A-Z / Z-A">
                            ⇅
                        </button>
                    </div>
                    <div class="pm-filter-row">
                        <button class="pm-filter-chip @(_devHealthFilter == null ? "pm-filter-chip--active" : "")" @onclick='() => _devHealthFilter = null'>All</button>
                        <button class="pm-filter-chip @(_devHealthFilter == DeveloperHealthStatus.Healthy ? "pm-filter-chip--active" : "")" @onclick='() => ToggleDevHealthFilter(DeveloperHealthStatus.Healthy)'>Healthy</button>
                        <button class="pm-filter-chip @(_devHealthFilter == DeveloperHealthStatus.Unhealthy ? "pm-filter-chip--active" : "")" @onclick='() => ToggleDevHealthFilter(DeveloperHealthStatus.Unhealthy)'>Unhealthy</button>
                        <span class="pm-filter-divider"></span>
                        <button class="pm-filter-chip @(_devWorkloadFilter == null ? "pm-filter-chip--active" : "")" @onclick='() => _devWorkloadFilter = null'>All</button>
                        <button class="pm-filter-chip @(_devWorkloadFilter == DeveloperWorkloadStatus.Standby ? "pm-filter-chip--active" : "")" @onclick='() => ToggleDevWorkloadFilter(DeveloperWorkloadStatus.Standby)'>Standby</button>
                        <button class="pm-filter-chip @(_devWorkloadFilter == DeveloperWorkloadStatus.UnderLoaded ? "pm-filter-chip--active" : "")" @onclick='() => ToggleDevWorkloadFilter(DeveloperWorkloadStatus.UnderLoaded)'>Under</button>
                        <button class="pm-filter-chip @(_devWorkloadFilter == DeveloperWorkloadStatus.Balanced ? "pm-filter-chip--active" : "")" @onclick='() => ToggleDevWorkloadFilter(DeveloperWorkloadStatus.Balanced)'>Balanced</button>
                        <button class="pm-filter-chip @(_devWorkloadFilter == DeveloperWorkloadStatus.Overloaded ? "pm-filter-chip--active" : "")" @onclick='() => ToggleDevWorkloadFilter(DeveloperWorkloadStatus.Overloaded)'>Overloaded</button>
                    </div>
                    <div class="pm-filter-row pm-filter-row--range">
                        <span class="pm-filter-range-label">Projects</span>
                        <input class="pm-filter-range" type="range" min="0" max="@_maxDevProjects" step="1"
                               value="@_devMinProjects" @oninput="e => _devMinProjects = int.Parse(e.Value!.ToString()!)" />
                        <span class="pm-filter-range-val">≥ @_devMinProjects</span>
                        <span class="pm-filter-divider"></span>
                        <span class="pm-filter-range-label">Work Items</span>
                        <input class="pm-filter-range" type="range" min="0" max="@_maxDevWorkItems" step="1"
                               value="@_devMinWorkItems" @oninput="e => _devMinWorkItems = int.Parse(e.Value!.ToString()!)" />
                        <span class="pm-filter-range-val">≥ @_devMinWorkItems</span>
                    </div>
                </div>
                <div class="pm-card-body">
                    @if (!FilteredDevelopers.Any())
                    {
                        <div class="pm-empty">
                            <span class="pm-empty-icon">⬡</span>
                            <p>No developers match filters.</p>
                        </div>
                    }
                    else
                    {
                        <div class="pm-list">
                            @foreach (var dev in FilteredDevelopers)
                            {
                                var devWorkItemCount = VisibleWorkItems.Count(w => w.Developer == dev.Name);
                                var isCurrentUser = dev.Name == _currentAccount?.DisplayName;
                                <div class="pm-list-item pm-list-item--clickable" @onclick="() => _detailModal.OpenDeveloper(dev)">
                                    <div class="pm-list-item-accent pm-list-item-accent--developers"></div>
                                    @if (!string.IsNullOrEmpty(dev.ImagePath))
                                    {
                                        <img class="pm-avatar pm-avatar--img" src="@dev.ImagePath" alt="@dev.Name" />
                                    }
                                    else
                                    {
                                        <div class="pm-avatar">@GetInitials(dev.Name)</div>
                                    }
                                    <div class="pm-list-item-content">
                                        <div class="pm-item-name-row">
                                            <span class="pm-item-name">@dev.Name</span>
                                            @if (isCurrentUser)
                                            {
                                                <span class="pm-you-badge">you</span>
                                            }
                                        </div>
                                        <span class="pm-item-sub">@dev.Assignments.Count proj · @devWorkItemCount items</span>
                                    </div>
                                    <div class="pm-item-pills">
                                        <span class="pm-pill pm-pill--workload-@dev.Workload.ToString().ToLower()">@FormatEnum(dev.Workload)</span>
                                        <span class="pm-pill pm-pill--health-@dev.Health.ToString().ToLower()">@dev.Health</span>
                                    </div>
                                    <span class="pm-list-item-arrow">›</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="pm-card pm-card--wide">
                <div class="pm-card-header">
                    <div class="pm-card-title-row">
                        <span class="pm-card-icon pm-card-icon--workitems">▣</span>
                        <h2 class="pm-card-title">Work Items</h2>
                        <span class="pm-badge">@VisibleWorkItems.Count</span>
                    </div>
                </div>
                <div class="pm-card-body">
                    @if (!VisibleWorkItems.Any())
                    {
                        <div class="pm-empty">
                            <span class="pm-empty-icon">▣</span>
                            <p>No work items yet.</p>
                        </div>
                    }
                    else
                    {
                        <div class="pm-table-wrap">
                            <table class="pm-table">
                                <thead>
                                    <tr>
                                        <th>Reference</th>
                                        <th>Project</th>
                                        <th>Developer</th>
                                        <th>Status</th>
                                        <th>UID</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in VisibleWorkItems)
                                    {
                                        var dev = VisibleDevelopers.FirstOrDefault(d => d.Name == item.Developer);
                                        var proj = _projects.FirstOrDefault(p => p.Uid == item.ProjectUid);
                                        var isCurrentUserItem = item.Developer == _currentAccount?.DisplayName;
                                        <tr class="pm-table-row pm-table-row--clickable" @onclick="() => _detailModal.OpenWorkItem(item)">
                                            <td><span class="pm-item-name">@item.Reference</span></td>
                                            <td>
                                                @if (proj is not null)
                                                {
                                                    <span class="pm-tag">@proj.Title</span>
                                                }
                                                else
                                                {
                                                    <span class="pm-item-sub">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (dev is not null)
                                                {
                                                    <div class="pm-assignee">
                                                        @if (!string.IsNullOrEmpty(dev.ImagePath))
                                                        {
                                                            <img class="pm-avatar pm-avatar--sm pm-avatar--img" src="@dev.ImagePath" alt="@dev.Name" />
                                                        }
                                                        else
                                                        {
                                                            <div class="pm-avatar pm-avatar--sm">@GetInitials(dev.Name)</div>
                                                        }
                                                        <span>@dev.Name</span>
                                                        @if (isCurrentUserItem)
                                                        {
                                                            <span class="pm-you-badge">you</span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="pm-item-sub">@(string.IsNullOrEmpty(item.Developer) ? "Unassigned" : item.Developer)</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="pm-status-pill pm-status-pill--@GetWorkItemStatusClass(item.Status)">
                                                    @FormatEnum(item.Status)
                                                </span>
                                            </td>
                                            <td><span class="pm-item-id">@item.Uid</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </section>

        </div>
    }
</div>

<EntityDetailModal @ref="_detailModal"
                   AllProjects="@_projects"
                   AllDevelopers="@VisibleDevelopers"
                   AllWorkItems="@VisibleWorkItems"
                   OnClose="@(() => StateHasChanged())"
                   OnDataChanged="RefreshData" />

<DataControlsFloat OnDataChanged="RefreshData" />

@code {
    private List<Project> _projects = [];
    private List<Developer> _developers = [];
    private List<WorkItem> _workItems = [];
    private Account? _currentAccount;
    private ManagerInfo _manager = new("Manager", "", "Project Management Dashboard");
    private bool _isLoading = true;

    private EntityDetailModal _detailModal = default!;

    private ProjectActivityStatus? _projActivityFilter = null;
    private ProjectPriorityStatus? _projPriorityFilter = null;
    private string _projSearch = string.Empty;
    private bool _projSortAsc = true;

    private DeveloperHealthStatus? _devHealthFilter = null;
    private DeveloperWorkloadStatus? _devWorkloadFilter = null;
    private int _devMinProjects = 0;
    private int _devMinWorkItems = 0;
    private string _devSearch = string.Empty;
    private bool _devSortAsc = true;

    private int _maxDevProjects => VisibleDevelopers.Any() ? VisibleDevelopers.Max(d => d.Assignments.Count) : 0;
    private int _maxDevWorkItems => VisibleDevelopers.Any() ? VisibleDevelopers.Max(d => VisibleWorkItems.Count(w => w.Developer == d.Name)) : 0;

    private List<Developer> VisibleDevelopers
        => _developers.Where(d => d.Name != _manager.DisplayName).ToList();

    private List<WorkItem> VisibleWorkItems
        => _workItems.Where(w => w.Developer != _manager.DisplayName).ToList();

    private List<Project> FilteredProjects
    {
        get
        {
            var q = _projects
                .Where(p => _projActivityFilter == null || p.Activity == _projActivityFilter)
                .Where(p => _projPriorityFilter == null || p.Priority == _projPriorityFilter)
                .Where(p => string.IsNullOrWhiteSpace(_projSearch) || p.Title.Contains(_projSearch, StringComparison.OrdinalIgnoreCase));
            q = _projSortAsc ? q.OrderBy(p => p.Title) : q.OrderByDescending(p => p.Title);
            return q.ToList();
        }
    }

    private List<Developer> FilteredDevelopers
    {
        get
        {
            var q = VisibleDevelopers
                .Where(d => _devHealthFilter == null || d.Health == _devHealthFilter)
                .Where(d => _devWorkloadFilter == null || d.Workload == _devWorkloadFilter)
                .Where(d => d.Assignments.Count >= _devMinProjects)
                .Where(d => VisibleWorkItems.Count(w => w.Developer == d.Name) >= _devMinWorkItems)
                .Where(d => string.IsNullOrWhiteSpace(_devSearch) || d.Name.Contains(_devSearch, StringComparison.OrdinalIgnoreCase));
            q = _devSortAsc ? q.OrderBy(d => d.Name) : q.OrderByDescending(d => d.Name);
            return q.ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var isAuth = await AppAuthentication.IsAuthenticatedAsync();
        if (!isAuth)
        {
            Nav.NavigateTo("/auth");
            return;
        }

        _currentAccount = await AppAuthentication.GetCurrentAccountAsync();
        _manager = await AppAuthentication.GetManagerInfoAsync();
        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        await Task.Yield();

        var result = AppServices.LoadAllDataSource();
        _projects = result.Projects;
        _developers = result.Developers;
        _workItems = result.WorkItems;

        _isLoading = false;
    }

    private async Task RefreshData()
    {
        AppServices.InvalidateCache();
        await LoadData();
        StateHasChanged();
    }

    private async Task HandleSignOut()
    {
        await AppAuthentication.SignOutAsync();
        Nav.NavigateTo("/auth");
    }

    private void ToggleProjActivityFilter(ProjectActivityStatus val)
        => _projActivityFilter = _projActivityFilter == val ? null : val;

    private void ToggleProjPriorityFilter(ProjectPriorityStatus val)
        => _projPriorityFilter = _projPriorityFilter == val ? null : val;

    private void ToggleDevHealthFilter(DeveloperHealthStatus val)
        => _devHealthFilter = _devHealthFilter == val ? null : val;

    private void ToggleDevWorkloadFilter(DeveloperWorkloadStatus val)
        => _devWorkloadFilter = _devWorkloadFilter == val ? null : val;

    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name[..Math.Min(2, name.Length)].ToUpper();
    }

    private static string FormatEnum<T>(T value) where T : Enum
        => System.Text.RegularExpressions.Regex.Replace(value.ToString(), "([a-z])([A-Z])", "$1 $2");

    private static string GetActivityClass(ProjectActivityStatus s) => s switch
    {
        ProjectActivityStatus.HighActivity => "high",
        ProjectActivityStatus.ModerateActivity => "moderate",
        ProjectActivityStatus.LowActivity => "low",
        _ => "low"
    };

    private static string GetWorkItemStatusClass(WorkItemStatus s) => s switch
    {
        WorkItemStatus.Investigating => "investigating",
        WorkItemStatus.ImplementingSolution => "implementing",
        WorkItemStatus.WaitingForConfirmation => "waiting",
        WorkItemStatus.DevDeployed => "dev-deployed",
        WorkItemStatus.UatDeployed => "uat-deployed",
        WorkItemStatus.ProdDeployed => "prod-deployed",
        _ => "unknown"
    };
}
