@page "/auth"
@inject IAppAuthentication AppAuthentication
@inject IAppServices AppServices
@inject NavigationManager Nav

<div class="auth-root">
    <div class="auth-card">
        <div class="auth-header">
            <img src="@_manager.ImagePath" alt="@_manager.DisplayName" class="auth-logo" />
            <h1 class="auth-title">@_manager.Title</h1>
            <p class="auth-subtitle">Sign in to continue</p>
        </div>

        <div class="auth-body">
            @if (_isChecking)
            {
                <div class="auth-loading">
                    <div class="pm-spinner"></div>
                </div>
            }
            else
            {
                <div class="auth-field">
                    <label class="auth-label">Account</label>
                    <select class="auth-select" @bind="_selectedDisplayName" @bind:after="OnAccountSelected">
                        <option value="">— Select account —</option>
                        @foreach (var account in _accounts)
                        {
                            <option value="@account.DisplayName">@account.DisplayName</option>
                        }
                    </select>
                </div>

                <div class="auth-field">
                    <label class="auth-label">Password</label>
                    <input class="auth-input"
                           type="password"
                           placeholder="Enter password"
                           @bind="_password"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>

                @if (_hasError)
                {
                    <div class="auth-error">Invalid account or password.</div>
                }

                <button class="auth-btn"
                        disabled="@(_isBusy || string.IsNullOrEmpty(_selectedDisplayName) || string.IsNullOrEmpty(_password))"
                        @onclick="HandleSignIn">
                    @if (_isBusy)
                    {
                        <div class="pm-spinner pm-spinner--sm"></div>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>
            }
        </div>
    </div>
</div>

@code {
    private List<Account> _accounts = [];
    private string _selectedDisplayName = string.Empty;
    private string _password = string.Empty;
    private bool _hasError = false;
    private bool _isBusy = false;
    private bool _isChecking = true;
    private ManagerInfo _manager = new("Manager", DeveloperImagePaths.Khen, "Mngr. Dashboard");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var isAuth = await AppAuthentication.IsAuthenticatedAsync();
        if (isAuth)
        {
            Nav.NavigateTo("/");
            return;
        }

        _accounts = AppServices.LoadAccounts();
        _isChecking = false;
        StateHasChanged();
    }

    private void OnAccountSelected()
    {
        if (string.IsNullOrEmpty(_selectedDisplayName)) return;
        _manager = ManagerInfo.FromDisplayName(_selectedDisplayName);
        _hasError = false;
    }

    private async Task HandleSignIn()
    {
        _hasError = false;
        _isBusy = true;

        var success = await AppAuthentication.SignInAsync(_selectedDisplayName, _password);

        if (success)
        {
            Nav.NavigateTo("/");
        }
        else
        {
            _hasError = true;
            _isBusy = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await HandleSignIn();
    }
}
