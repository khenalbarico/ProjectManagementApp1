@inject IAppRepository AppRepository
@inject IAppServices AppServices

<div class="pm-modal-backdrop" @onclick="HandleBackdropClick">
    <div class="pm-modal" @onclick:stopPropagation="true">

        <div class="pm-modal-header">
            <h2 class="pm-modal-title">Manage Data</h2>
            <button class="pm-modal-close" @onclick="Close">✕</button>
        </div>

        <div class="pm-modal-tabs">
            <button class="pm-tab @(_activeTab == Tab.Projects ? "pm-tab--active" : "")" @onclick='() => SetTab(Tab.Projects)'>
                <span class="pm-tab-icon">◈</span> Projects
            </button>
            <button class="pm-tab @(_activeTab == Tab.Developers ? "pm-tab--active" : "")" @onclick='() => SetTab(Tab.Developers)'>
                <span class="pm-tab-icon">⬡</span> Developers
            </button>
            <button class="pm-tab @(_activeTab == Tab.WorkItems ? "pm-tab--active" : "")" @onclick='() => SetTab(Tab.WorkItems)'>
                <span class="pm-tab-icon">▣</span> Work Items
            </button>
        </div>

        <div class="pm-modal-body">

            @if (!string.IsNullOrEmpty(_successMsg))
            {
                <div class="pm-alert pm-alert--success">@_successMsg</div>
            }
            @if (!string.IsNullOrEmpty(_errorMsg))
            {
                <div class="pm-alert pm-alert--error">@_errorMsg</div>
            }

            @if (_activeTab == Tab.Projects)
            {
                <div class="pm-form-section">
                    <div class="pm-form-mode-toggle">
                        <button class="pm-mode-btn @(_projectMode == FormMode.Add ? "active" : "")" @onclick='() => SwitchProjectMode(FormMode.Add)'>+ Add New</button>
                        <button class="pm-mode-btn @(_projectMode == FormMode.Edit ? "active" : "")" @onclick='() => SwitchProjectMode(FormMode.Edit)'>✎ Edit</button>
                        <button class="pm-mode-btn @(_projectMode == FormMode.Delete ? "active" : "")" @onclick='() => SwitchProjectMode(FormMode.Delete)'>✕ Delete</button>
                    </div>

                    @if (_projectMode == FormMode.Add)
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">Title <span class="pm-required">*</span></label>
                                <input class="pm-input" placeholder="e.g. Phoenix Rewrite" @bind="_newProject.Title" />
                            </div>
                            <div class="pm-field-row">
                                <div class="pm-field">
                                    <label class="pm-label">Priority</label>
                                    <select class="pm-input pm-select" @bind="_newProject.Priority">
                                        @foreach (var val in Enum.GetValues<ProjectPriorityStatus>())
                                        {
                                            <option value="@val">@FormatEnum(val)</option>
                                        }
                                    </select>
                                </div>
                                <div class="pm-field">
                                    <label class="pm-label">Activity</label>
                                    <select class="pm-input pm-select" @bind="_newProject.Activity">
                                        @foreach (var val in Enum.GetValues<ProjectActivityStatus>())
                                        {
                                            <option value="@val">@FormatEnum(val)</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="pm-field">
                                <label class="pm-label">Key Person</label>
                                <select class="pm-input pm-select" @bind="_newProject.KeyPerson">
                                    @foreach (var val in Enum.GetValues<KeyPersons>())
                                    {
                                        <option value="@val">@val</option>
                                    }
                                </select>
                            </div>
                            <button class="pm-btn pm-btn--primary" @onclick="AddProject" disabled="@_isSaving">
                                @(_isSaving ? "Saving..." : "Add Project")
                            </button>
                        </div>
                    }
                    else if (_projectMode == FormMode.Edit)
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">UID <span class="pm-required">*</span></label>
                                <div class="pm-lookup-row">
                                    <input class="pm-input pm-input--mono" placeholder="PRJ-XXXXX"
                                           @bind="_editProjectUid" @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") LookupProject(); })" />
                                    <button class="pm-btn pm-btn--lookup" @onclick="LookupProject" disabled="@string.IsNullOrWhiteSpace(_editProjectUid)">
                                        Fetch
                                    </button>
                                </div>
                            </div>

                            @if (_projectLookupDone)
                            {
                                @if (_editProject is null)
                                {
                                    <div class="pm-lookup-notfound">No project found with that UID.</div>
                                }
                                else
                                {
                                    <div class="pm-lookup-found">
                                        <span class="pm-lookup-found-icon">✓</span> Loaded: <strong>@_editProject.Title</strong>
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Title</label>
                                        <input class="pm-input" @bind="_editProject.Title" />
                                    </div>
                                    <div class="pm-field-row">
                                        <div class="pm-field">
                                            <label class="pm-label">Priority</label>
                                            <select class="pm-input pm-select" @bind="_editProject.Priority">
                                                @foreach (var val in Enum.GetValues<ProjectPriorityStatus>())
                                                {
                                                    <option value="@val">@FormatEnum(val)</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="pm-field">
                                            <label class="pm-label">Activity</label>
                                            <select class="pm-input pm-select" @bind="_editProject.Activity">
                                                @foreach (var val in Enum.GetValues<ProjectActivityStatus>())
                                                {
                                                    <option value="@val">@FormatEnum(val)</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Key Person</label>
                                        <select class="pm-input pm-select" @bind="_editProject.KeyPerson">
                                            @foreach (var val in Enum.GetValues<KeyPersons>())
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        </select>
                                    </div>
                                    <button class="pm-btn pm-btn--secondary" @onclick="EditProject" disabled="@_isSaving">
                                        @(_isSaving ? "Saving..." : "Update Project")
                                    </button>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">UID <span class="pm-required">*</span></label>
                                <div class="pm-lookup-row">
                                    <input class="pm-input pm-input--mono" placeholder="PRJ-XXXXX"
                                           @bind="_deleteProjectUid" @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") LookupProjectForDelete(); })" />
                                    <button class="pm-btn pm-btn--lookup" @onclick="LookupProjectForDelete" disabled="@string.IsNullOrWhiteSpace(_deleteProjectUid)">
                                        Fetch
                                    </button>
                                </div>
                            </div>

                            @if (_projectDeleteLookupDone)
                            {
                                @if (_deleteProject is null)
                                {
                                    <div class="pm-lookup-notfound">No project found with that UID.</div>
                                }
                                else
                                {
                                    <div class="pm-delete-confirm">
                                        <div class="pm-delete-confirm-icon">⚠</div>
                                        <div class="pm-delete-confirm-text">
                                            <strong>@_deleteProject.Title</strong>
                                            <span>@_deleteProject.Uid</span>
                                        </div>
                                    </div>
                                    <div class="pm-alert pm-alert--error" style="margin-bottom:0;">
                                        This will permanently remove the project. Work items linked to this project will be unaffected.
                                    </div>
                                    <button class="pm-btn pm-btn--danger" @onclick="DeleteProject" disabled="@_isSaving">
                                        @(_isSaving ? "Deleting..." : "Delete Project")
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            }

            @if (_activeTab == Tab.Developers)
            {
                <div class="pm-form-section">
                    <div class="pm-form-mode-toggle">
                        <button class="pm-mode-btn @(_devMode == FormMode.Add ? "active" : "")" @onclick='() => SwitchDevMode(FormMode.Add)'>+ Add New</button>
                        <button class="pm-mode-btn @(_devMode == FormMode.Edit ? "active" : "")" @onclick='() => SwitchDevMode(FormMode.Edit)'>✎ Edit</button>
                        <button class="pm-mode-btn @(_devMode == FormMode.Delete ? "active" : "")" @onclick='() => SwitchDevMode(FormMode.Delete)'>✕ Delete</button>
                    </div>

                    @if (_devMode == FormMode.Add)
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">Name <span class="pm-required">*</span></label>
                                <input class="pm-input" placeholder="e.g. Jane Santos" @bind="_newDev.Name" />
                            </div>
                            <div class="pm-field">
                                <label class="pm-label">Health</label>
                                <select class="pm-input pm-select" @bind="_newDev.Health">
                                    @foreach (var val in Enum.GetValues<DeveloperHealthStatus>())
                                    {
                                        <option value="@val">@val</option>
                                    }
                                </select>
                            </div>
                            <div class="pm-field">
                                <label class="pm-label">Project Assignments</label>
                                @if (!_allProjects.Any())
                                {
                                    <p class="pm-item-sub">No projects available. Add a project first.</p>
                                }
                                else
                                {
                                    @foreach (var assignment in _newDevAssignments)
                                    {
                                        var a = assignment;
                                        var usedUids = _newDevAssignments.Where(x => x != a).Select(x => x.ProjectUid).ToHashSet();
                                        <div class="pm-assignment-row">
                                            <select class="pm-input pm-select pm-select--assignment" @bind="a.ProjectUid">
                                                <option value="">— Select Project —</option>
                                                @foreach (var proj in _allProjects)
                                                {
                                                    if (!usedUids.Contains(proj.Uid) || a.ProjectUid == proj.Uid)
                                                    {
                                                        <option value="@proj.Uid">@proj.Title</option>
                                                    }
                                                }
                                            </select>
                                            <select class="pm-input pm-select pm-select--exposure" @bind="a.ProjectExposure">
                                                @foreach (var val in Enum.GetValues<DeveloperProjectExposureStatus>())
                                                {
                                                    <option value="@val.ToString()">@FormatEnum(val)</option>
                                                }
                                            </select>
                                            <button class="pm-btn-icon pm-btn-icon--remove" @onclick="() => _newDevAssignments.Remove(a)">✕</button>
                                        </div>
                                    }
                                    <button class="pm-btn pm-btn--ghost pm-btn--sm" @onclick="() => _newDevAssignments.Add(new ProjectAssignment())">+ Add Project</button>
                                }
                            </div>
                            <button class="pm-btn pm-btn--primary" @onclick="AddDeveloper" disabled="@_isSaving">
                                @(_isSaving ? "Saving..." : "Add Developer")
                            </button>
                        </div>
                    }
                    else if (_devMode == FormMode.Edit)
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">UID <span class="pm-required">*</span></label>
                                <div class="pm-lookup-row">
                                    <input class="pm-input pm-input--mono" placeholder="DEV-XXXXX"
                                           @bind="_editDevUid" @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") LookupDeveloper(); })" />
                                    <button class="pm-btn pm-btn--lookup" @onclick="LookupDeveloper" disabled="@string.IsNullOrWhiteSpace(_editDevUid)">
                                        Fetch
                                    </button>
                                </div>
                            </div>

                            @if (_devLookupDone)
                            {
                                @if (_editDev is null)
                                {
                                    <div class="pm-lookup-notfound">No developer found with that UID.</div>
                                }
                                else
                                {
                                    <div class="pm-lookup-found">
                                        <span class="pm-lookup-found-icon">✓</span> Loaded: <strong>@_editDev.Name</strong>
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Name</label>
                                        <input class="pm-input" @bind="_editDev.Name" />
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Health</label>
                                        <select class="pm-input pm-select" @bind="_editDev.Health">
                                            @foreach (var val in Enum.GetValues<DeveloperHealthStatus>())
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Project Assignments</label>
                                        @if (!_allProjects.Any())
                                        {
                                            <p class="pm-item-sub">No projects available.</p>
                                        }
                                        else
                                        {
                                            @foreach (var assignment in _editDevAssignments)
                                            {
                                                var a = assignment;
                                                var usedUids = _editDevAssignments.Where(x => x != a).Select(x => x.ProjectUid).ToHashSet();
                                                <div class="pm-assignment-row">
                                                    <select class="pm-input pm-select pm-select--assignment" @bind="a.ProjectUid">
                                                        <option value="">— Select Project —</option>
                                                        @foreach (var proj in _allProjects)
                                                        {
                                                            if (!usedUids.Contains(proj.Uid) || a.ProjectUid == proj.Uid)
                                                            {
                                                                <option value="@proj.Uid">@proj.Title</option>
                                                            }
                                                        }
                                                    </select>
                                                    <select class="pm-input pm-select pm-select--exposure" @bind="a.ProjectExposure">
                                                        @foreach (var val in Enum.GetValues<DeveloperProjectExposureStatus>())
                                                        {
                                                            <option value="@val.ToString()">@FormatEnum(val)</option>
                                                        }
                                                    </select>
                                                    <button class="pm-btn-icon pm-btn-icon--remove" @onclick="() => _editDevAssignments.Remove(a)">✕</button>
                                                </div>
                                            }
                                            <button class="pm-btn pm-btn--ghost pm-btn--sm" @onclick="() => _editDevAssignments.Add(new ProjectAssignment())">+ Add Project</button>
                                        }
                                    </div>
                                    <button class="pm-btn pm-btn--secondary" @onclick="EditDeveloper" disabled="@_isSaving">
                                        @(_isSaving ? "Saving..." : "Update Developer")
                                    </button>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">UID <span class="pm-required">*</span></label>
                                <div class="pm-lookup-row">
                                    <input class="pm-input pm-input--mono" placeholder="DEV-XXXXX"
                                           @bind="_deleteDevUid" @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") LookupDeveloperForDelete(); })" />
                                    <button class="pm-btn pm-btn--lookup" @onclick="LookupDeveloperForDelete" disabled="@string.IsNullOrWhiteSpace(_deleteDevUid)">
                                        Fetch
                                    </button>
                                </div>
                            </div>

                            @if (_devDeleteLookupDone)
                            {
                                @if (_deleteDev is null)
                                {
                                    <div class="pm-lookup-notfound">No developer found with that UID.</div>
                                }
                                else
                                {
                                    <div class="pm-delete-confirm">
                                        <div class="pm-delete-confirm-icon">⚠</div>
                                        <div class="pm-delete-confirm-text">
                                            <strong>@_deleteDev.Name</strong>
                                            <span>@_deleteDev.Uid</span>
                                        </div>
                                    </div>
                                    <div class="pm-alert pm-alert--error" style="margin-bottom:0;">
                                        This will permanently remove the developer. Work items assigned to this developer will be unaffected.
                                    </div>
                                    <button class="pm-btn pm-btn--danger" @onclick="DeleteDeveloper" disabled="@_isSaving">
                                        @(_isSaving ? "Deleting..." : "Delete Developer")
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            }

            @if (_activeTab == Tab.WorkItems)
            {
                <div class="pm-form-section">
                    <div class="pm-form-mode-toggle">
                        <button class="pm-mode-btn @(_workItemMode == FormMode.Add ? "active" : "")" @onclick='() => SwitchWorkItemMode(FormMode.Add)'>+ Add New</button>
                        <button class="pm-mode-btn @(_workItemMode == FormMode.Edit ? "active" : "")" @onclick='() => SwitchWorkItemMode(FormMode.Edit)'>✎ Edit</button>
                        <button class="pm-mode-btn @(_workItemMode == FormMode.Delete ? "active" : "")" @onclick='() => SwitchWorkItemMode(FormMode.Delete)'>✕ Delete</button>
                    </div>

                    @if (_workItemMode == FormMode.Add)
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">Reference <span class="pm-required">*</span></label>
                                <input class="pm-input" placeholder="e.g. https://dev.azure.com/..." @bind="_newWorkItem.Reference" />
                            </div>
                            <div class="pm-field">
                                <label class="pm-label">Project</label>
                                @if (!_allProjects.Any())
                                {
                                    <p class="pm-item-sub">No projects available.</p>
                                }
                                else
                                {
                                    <select class="pm-input pm-select" @bind="_newWorkItem.ProjectUid">
                                        <option value="">— Unassigned —</option>
                                        @foreach (var proj in _allProjects)
                                        {
                                            <option value="@proj.Uid">@proj.Title</option>
                                        }
                                    </select>
                                }
                            </div>
                            <div class="pm-field">
                                <label class="pm-label">Developer</label>
                                @if (!_allDevelopers.Any())
                                {
                                    <p class="pm-item-sub">No developers available.</p>
                                }
                                else
                                {
                                    <select class="pm-input pm-select" @bind="_newWorkItem.Developer">
                                        <option value="">— Unassigned —</option>
                                        @foreach (var dev in _allDevelopers)
                                        {
                                            <option value="@dev.Name">@dev.Name</option>
                                        }
                                    </select>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(_newWorkItem.Developer))
                            {
                                <div class="pm-field">
                                    <label class="pm-label">Status</label>
                                    <select class="pm-input pm-select" @bind="_newWorkItem.Status">
                                        @foreach (var val in Enum.GetValues<WorkItemStatus>())
                                        {
                                            <option value="@val">@FormatEnum(val)</option>
                                        }
                                    </select>
                                </div>
                            }
                            <button class="pm-btn pm-btn--primary" @onclick="AddWorkItem" disabled="@_isSaving">
                                @(_isSaving ? "Saving..." : "Add Work Item")
                            </button>
                        </div>
                    }
                    else if (_workItemMode == FormMode.Edit)
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">UID <span class="pm-required">*</span></label>
                                <div class="pm-lookup-row">
                                    <input class="pm-input pm-input--mono" placeholder="WRK-XXXXX"
                                           @bind="_editWorkItemUid" @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") LookupWorkItem(); })" />
                                    <button class="pm-btn pm-btn--lookup" @onclick="LookupWorkItem" disabled="@string.IsNullOrWhiteSpace(_editWorkItemUid)">
                                        Fetch
                                    </button>
                                </div>
                            </div>

                            @if (_workItemLookupDone)
                            {
                                @if (_editWorkItem is null)
                                {
                                    <div class="pm-lookup-notfound">No work item found with that UID.</div>
                                }
                                else
                                {
                                    <div class="pm-lookup-found">
                                        <span class="pm-lookup-found-icon">✓</span> Loaded: <strong class="pm-font-mono">@_editWorkItem.Uid</strong>
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Reference</label>
                                        <input class="pm-input" @bind="_editWorkItem.Reference" />
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Project</label>
                                        @if (!_allProjects.Any())
                                        {
                                            <p class="pm-item-sub">No projects available.</p>
                                        }
                                        else
                                        {
                                            <select class="pm-input pm-select" @bind="_editWorkItem.ProjectUid">
                                                <option value="">— Unassigned —</option>
                                                @foreach (var proj in _allProjects)
                                                {
                                                    <option value="@proj.Uid">@proj.Title</option>
                                                }
                                            </select>
                                        }
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Developer</label>
                                        @if (!_allDevelopers.Any())
                                        {
                                            <p class="pm-item-sub">No developers available.</p>
                                        }
                                        else
                                        {
                                            <select class="pm-input pm-select" @bind="_editWorkItem.Developer">
                                                <option value="">— Unassigned —</option>
                                                @foreach (var dev in _allDevelopers)
                                                {
                                                    <option value="@dev.Name">@dev.Name</option>
                                                }
                                            </select>
                                        }
                                    </div>
                                    <div class="pm-field">
                                        <label class="pm-label">Status</label>
                                        <select class="pm-input pm-select" @bind="_editWorkItem.Status">
                                            @foreach (var val in Enum.GetValues<WorkItemStatus>())
                                            {
                                                <option value="@val">@FormatEnum(val)</option>
                                            }
                                        </select>
                                    </div>
                                    <button class="pm-btn pm-btn--secondary" @onclick="EditWorkItem" disabled="@_isSaving">
                                        @(_isSaving ? "Saving..." : "Update Work Item")
                                    </button>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <div class="pm-form">
                            <div class="pm-field">
                                <label class="pm-label">UID <span class="pm-required">*</span></label>
                                <div class="pm-lookup-row">
                                    <input class="pm-input pm-input--mono" placeholder="WRK-XXXXX"
                                           @bind="_deleteWorkItemUid" @bind:event="oninput"
                                           @onkeydown="@(e => { if (e.Key == "Enter") LookupWorkItemForDelete(); })" />
                                    <button class="pm-btn pm-btn--lookup" @onclick="LookupWorkItemForDelete" disabled="@string.IsNullOrWhiteSpace(_deleteWorkItemUid)">
                                        Fetch
                                    </button>
                                </div>
                            </div>

                            @if (_workItemDeleteLookupDone)
                            {
                                @if (_deleteWorkItem is null)
                                {
                                    <div class="pm-lookup-notfound">No work item found with that UID.</div>
                                }
                                else
                                {
                                    <div class="pm-delete-confirm">
                                        <div class="pm-delete-confirm-icon">⚠</div>
                                        <div class="pm-delete-confirm-text">
                                            <strong class="pm-font-mono">@_deleteWorkItem.Uid</strong>
                                            <span>@_deleteWorkItem.Reference</span>
                                        </div>
                                    </div>
                                    <div class="pm-alert pm-alert--error" style="margin-bottom:0;">
                                        This will permanently remove the work item.
                                    </div>
                                    <button class="pm-btn pm-btn--danger" @onclick="DeleteWorkItem" disabled="@_isSaving">
                                        @(_isSaving ? "Deleting..." : "Delete Work Item")
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private enum Tab { Projects, Developers, WorkItems }
    private enum FormMode { Add, Edit, Delete }

    private Tab _activeTab = Tab.Projects;
    private FormMode _projectMode = FormMode.Add;
    private FormMode _devMode = FormMode.Add;
    private FormMode _workItemMode = FormMode.Add;

    private bool _isSaving = false;
    private string _successMsg = string.Empty;
    private string _errorMsg = string.Empty;

    private List<Project> _allProjects = [];
    private List<Developer> _allDevelopers = [];
    private List<WorkItem> _allWorkItems = [];

    private Project _newProject = new();
    private Developer _newDev = new();
    private WorkItem _newWorkItem = new();

    private List<ProjectAssignment> _newDevAssignments = [];
    private List<ProjectAssignment> _editDevAssignments = [];

    private string _editProjectUid = string.Empty;
    private string _editDevUid = string.Empty;
    private string _editWorkItemUid = string.Empty;

    private Project? _editProject = null;
    private Developer? _editDev = null;
    private WorkItem? _editWorkItem = null;

    private bool _projectLookupDone = false;
    private bool _devLookupDone = false;
    private bool _workItemLookupDone = false;

    private string _deleteProjectUid = string.Empty;
    private string _deleteDevUid = string.Empty;
    private string _deleteWorkItemUid = string.Empty;

    private Project? _deleteProject = null;
    private Developer? _deleteDev = null;
    private WorkItem? _deleteWorkItem = null;

    private bool _projectDeleteLookupDone = false;
    private bool _devDeleteLookupDone = false;
    private bool _workItemDeleteLookupDone = false;

    protected override void OnInitialized()
    {
        var data = AppServices.LoadAllDataSource();
        _allProjects   = data.Projects;
        _allDevelopers = data.Developers;
        _allWorkItems  = data.WorkItems;
    }

    private void SetTab(Tab tab)
    {
        _activeTab  = tab;
        _successMsg = string.Empty;
        _errorMsg   = string.Empty;
    }

    private void SwitchProjectMode(FormMode mode)
    {
        _projectMode            = mode;
        _editProjectUid         = string.Empty;
        _editProject            = null;
        _projectLookupDone      = false;
        _deleteProjectUid       = string.Empty;
        _deleteProject          = null;
        _projectDeleteLookupDone = false;
        _successMsg             = string.Empty;
        _errorMsg               = string.Empty;
    }

    private void SwitchDevMode(FormMode mode)
    {
        _devMode               = mode;
        _editDevUid            = string.Empty;
        _editDev               = null;
        _editDevAssignments    = [];
        _devLookupDone         = false;
        _deleteDevUid          = string.Empty;
        _deleteDev             = null;
        _devDeleteLookupDone   = false;
        _successMsg            = string.Empty;
        _errorMsg              = string.Empty;
    }

    private void SwitchWorkItemMode(FormMode mode)
    {
        _workItemMode              = mode;
        _editWorkItemUid           = string.Empty;
        _editWorkItem              = null;
        _workItemLookupDone        = false;
        _deleteWorkItemUid         = string.Empty;
        _deleteWorkItem            = null;
        _workItemDeleteLookupDone  = false;
        _successMsg                = string.Empty;
        _errorMsg                  = string.Empty;
    }

    private void LookupProject()
    {
        _projectLookupDone = true;
        _successMsg        = string.Empty;
        _errorMsg          = string.Empty;
        var found = _allProjects.FirstOrDefault(p => p.Uid.Equals(_editProjectUid.Trim(), StringComparison.OrdinalIgnoreCase));
        _editProject = found is null ? null : new Project
        {
            Uid       = found.Uid,
            Title     = found.Title,
            Priority  = found.Priority,
            Activity  = found.Activity,
            KeyPerson = found.KeyPerson
        };
    }

    private void LookupProjectForDelete()
    {
        _projectDeleteLookupDone = true;
        _successMsg              = string.Empty;
        _errorMsg                = string.Empty;
        _deleteProject = _allProjects.FirstOrDefault(p => p.Uid.Equals(_deleteProjectUid.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private void LookupDeveloper()
    {
        _devLookupDone = true;
        _successMsg    = string.Empty;
        _errorMsg      = string.Empty;
        var found = _allDevelopers.FirstOrDefault(d => d.Uid.Equals(_editDevUid.Trim(), StringComparison.OrdinalIgnoreCase));
        if (found is null)
        {
            _editDev            = null;
            _editDevAssignments = [];
        }
        else
        {
            _editDev = new Developer
            {
                Uid         = found.Uid,
                Name        = found.Name,
                Workload    = found.Workload,
                Health      = found.Health,
                Assignments = found.Assignments.Select(a => new ProjectAssignment
                {
                    ProjectUid      = a.ProjectUid,
                    ProjectExposure = a.ProjectExposure
                }).ToList(),
                ImagePath = found.ImagePath
            };
            _editDevAssignments = _editDev.Assignments;
        }
    }

    private void LookupDeveloperForDelete()
    {
        _devDeleteLookupDone = true;
        _successMsg          = string.Empty;
        _errorMsg            = string.Empty;
        _deleteDev = _allDevelopers.FirstOrDefault(d => d.Uid.Equals(_deleteDevUid.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private void LookupWorkItem()
    {
        _workItemLookupDone = true;
        _successMsg         = string.Empty;
        _errorMsg           = string.Empty;
        var data = AppServices.LoadAllDataSource();
        var found = data.WorkItems.FirstOrDefault(w => w.Uid.Equals(_editWorkItemUid.Trim(), StringComparison.OrdinalIgnoreCase));
        _editWorkItem = found is null ? null : new WorkItem
        {
            Uid        = found.Uid,
            Reference  = found.Reference,
            Developer  = found.Developer,
            ProjectUid = found.ProjectUid,
            Status     = found.Status
        };
    }

    private void LookupWorkItemForDelete()
    {
        _workItemDeleteLookupDone = true;
        _successMsg               = string.Empty;
        _errorMsg                 = string.Empty;
        var data = AppServices.LoadAllDataSource();
        _deleteWorkItem = data.WorkItems.FirstOrDefault(w => w.Uid.Equals(_deleteWorkItemUid.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private void Close() => OnClose.InvokeAsync();
    private void HandleBackdropClick() => Close();

    private async Task AddProject()
    {
        if (string.IsNullOrWhiteSpace(_newProject.Title)) { _errorMsg = "Title is required."; return; }
        var titleTrimmed = _newProject.Title.Trim();
        if (_allProjects.Any(p => p.Title.Equals(titleTrimmed, StringComparison.OrdinalIgnoreCase)))
        {
            _errorMsg = $"A project with the title \"{titleTrimmed}\" already exists.";
            return;
        }
        _newProject.Uid = Prefixes.ProjectPrefix.Generate();
        await SaveAsync(() => AppRepository.PostProject(_newProject));
        AppServices.InvalidateProjectsCache();
        _allProjects = AppServices.LoadAllDataSource().Projects;
        _newProject  = new();
    }

    private async Task EditProject()
    {
        if (_editProject is null) return;
        var titleTrimmed = _editProject.Title.Trim();
        if (_allProjects.Any(p => p.Title.Equals(titleTrimmed, StringComparison.OrdinalIgnoreCase) && p.Uid != _editProject.Uid))
        {
            _errorMsg = $"Another project with the title \"{titleTrimmed}\" already exists.";
            return;
        }
        await SaveAsync(() => AppRepository.PatchProject(_editProject));
        AppServices.InvalidateProjectsCache();
        _allProjects       = AppServices.LoadAllDataSource().Projects;
        _editProject       = null;
        _editProjectUid    = string.Empty;
        _projectLookupDone = false;
    }

    private async Task DeleteProject()
    {
        if (_deleteProject is null) return;
        await SaveAsync(() => AppRepository.DeleteProject(_deleteProject.Uid));
        AppServices.InvalidateProjectsCache();
        _allProjects             = AppServices.LoadAllDataSource().Projects;
        _deleteProject           = null;
        _deleteProjectUid        = string.Empty;
        _projectDeleteLookupDone = false;
    }

    private async Task AddDeveloper()
    {
        if (string.IsNullOrWhiteSpace(_newDev.Name)) { _errorMsg = "Name is required."; return; }
        var nameTrimmed = _newDev.Name.Trim();
        if (_allDevelopers.Any(d => d.Name.Equals(nameTrimmed, StringComparison.OrdinalIgnoreCase)))
        {
            _errorMsg = $"A developer named \"{nameTrimmed}\" already exists.";
            return;
        }
        _newDev.Uid         = Prefixes.DeveloperPrefix.Generate();
        _newDev.Assignments = _newDevAssignments.Where(a => !string.IsNullOrEmpty(a.ProjectUid)).ToList();
        await SaveAsync(() => AppRepository.PostDeveloper(_newDev));
        AppServices.InvalidateDevelopersCache();
        _allDevelopers     = AppServices.LoadAllDataSource().Developers;
        _newDev            = new();
        _newDevAssignments = [];
    }

    private async Task EditDeveloper()
    {
        if (_editDev is null) return;
        var nameTrimmed = _editDev.Name.Trim();
        if (_allDevelopers.Any(d => d.Name.Equals(nameTrimmed, StringComparison.OrdinalIgnoreCase) && d.Uid != _editDev.Uid))
        {
            _errorMsg = $"Another developer named \"{nameTrimmed}\" already exists.";
            return;
        }
        _editDev.Assignments = _editDevAssignments.Where(a => !string.IsNullOrEmpty(a.ProjectUid)).ToList();
        await SaveAsync(() => AppRepository.PatchDeveloper(_editDev));
        AppServices.InvalidateDevelopersCache();
        _allDevelopers      = AppServices.LoadAllDataSource().Developers;
        _editDev            = null;
        _editDevUid         = string.Empty;
        _editDevAssignments = [];
        _devLookupDone      = false;
    }

    private async Task DeleteDeveloper()
    {
        if (_deleteDev is null) return;
        await SaveAsync(() => AppRepository.DeleteDeveloper(_deleteDev.Uid));
        AppServices.InvalidateDevelopersCache();
        _allDevelopers       = AppServices.LoadAllDataSource().Developers;
        _deleteDev           = null;
        _deleteDevUid        = string.Empty;
        _devDeleteLookupDone = false;
    }

    private async Task AddWorkItem()
    {
        if (string.IsNullOrWhiteSpace(_newWorkItem.Reference)) { _errorMsg = "Reference is required."; return; }
        var refTrimmed = _newWorkItem.Reference.Trim();
        if (_allWorkItems.Any(w => w.Reference.Equals(refTrimmed, StringComparison.OrdinalIgnoreCase)))
        {
            _errorMsg = "A work item with that reference already exists.";
            return;
        }
        _newWorkItem.Uid = Prefixes.WorkitemPrefix.Generate();
        await SaveAsync(() => AppRepository.PostWorkItem(_newWorkItem));
        AppServices.InvalidateWorkItemsCache();
        _allWorkItems = AppServices.LoadAllDataSource().WorkItems;
        _newWorkItem  = new();
    }

    private async Task EditWorkItem()
    {
        if (_editWorkItem is null) return;
        var refTrimmed = _editWorkItem.Reference.Trim();
        if (_allWorkItems.Any(w => w.Reference.Equals(refTrimmed, StringComparison.OrdinalIgnoreCase) && w.Uid != _editWorkItem.Uid))
        {
            _errorMsg = "Another work item with that reference already exists.";
            return;
        }
        await SaveAsync(() => AppRepository.PatchWorkItem(_editWorkItem));
        AppServices.InvalidateWorkItemsCache();
        _allWorkItems       = AppServices.LoadAllDataSource().WorkItems;
        _editWorkItem       = null;
        _editWorkItemUid    = string.Empty;
        _workItemLookupDone = false;
    }

    private async Task DeleteWorkItem()
    {
        if (_deleteWorkItem is null) return;
        await SaveAsync(() => AppRepository.DeleteWorkItem(_deleteWorkItem.Uid));
        AppServices.InvalidateWorkItemsCache();
        _allWorkItems             = AppServices.LoadAllDataSource().WorkItems;
        _deleteWorkItem           = null;
        _deleteWorkItemUid        = string.Empty;
        _workItemDeleteLookupDone = false;
    }

    private async Task SaveAsync(Action saveAction)
    {
        _isSaving   = true;
        _successMsg = string.Empty;
        _errorMsg   = string.Empty;

        try
        {
            await Task.Run(saveAction);
            _successMsg = "Saved successfully.";
            await OnDataChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMsg = $"Error: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static string FormatEnum<T>(T value) where T : Enum
        => System.Text.RegularExpressions.Regex.Replace(value.ToString(), "([a-z])([A-Z])", "$1 $2");
}
