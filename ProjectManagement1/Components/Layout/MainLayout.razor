@inherits LayoutComponentBase

<div class="pm-app">
    @Body
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --bg:           #0d0f12;
        --bg-card:      #13161b;
        --bg-hover:     #1a1e25;
        --bg-input:     #0d0f12;
        --border:       #242830;
        --border-light: #2e333d;

        --text:         #e8eaf0;
        --text-sub:     #6b7280;
        --text-muted:   #3d4350;

        --accent-p:     #4f8ef7;
        --accent-d:     #34d399;
        --accent-w:     #f59e0b;

        --danger:       #f87171;
        --success:      #34d399;

        --radius:       6px;
        --radius-lg:    10px;

        --font-display: 'Syne', sans-serif;
        --font-mono:    'IBM Plex Mono', monospace;
    }

    html, body { background: var(--bg); color: var(--text); font-family: var(--font-display); }

    .pm-app { min-height: 100vh; background: var(--bg); }

    .pm-dashboard {
        max-width: 1280px;
        margin: 0 auto;
        padding: 2rem 1.5rem 6rem;
    }

    .pm-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 60vh;
        gap: 1rem;
        color: var(--text-sub);
        font-family: var(--font-mono);
        font-size: 0.85rem;
    }
    .pm-spinner {
        width: 32px; height: 32px;
        border: 2px solid var(--border);
        border-top-color: var(--accent-p);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .pm-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border);
    }
    .pm-header-left { display: flex; align-items: center; gap: 1rem; }
    .pm-logo-mark {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--accent-p), var(--accent-d));
        border-radius: var(--radius);
        flex-shrink: 0;
    }
    .pm-title {
        font-size: 1.6rem; font-weight: 800;
        letter-spacing: -0.03em; color: var(--text); line-height: 1;
    }
    .pm-subtitle {
        font-size: 0.75rem; color: var(--text-sub);
        font-family: var(--font-mono); margin-top: 2px;
    }
    .pm-header-stats {
        display: flex; align-items: center; gap: 1.25rem;
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius-lg); padding: 0.75rem 1.5rem;
    }
    .pm-stat { text-align: center; }
    .pm-stat-value { display: block; font-size: 1.4rem; font-weight: 700; color: var(--text); line-height: 1; }
    .pm-stat-label { font-size: 0.7rem; color: var(--text-sub); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.05em; }
    .pm-stat-divider { width: 1px; height: 32px; background: var(--border); }

    .pm-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
    }
    @@media (max-width: 900px) { .pm-grid { grid-template-columns: 1fr; } }

    .pm-card {
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius-lg); overflow: hidden;
        display: flex; flex-direction: column;
    }
    .pm-card--wide { grid-column: 1 / -1; }
    .pm-card-header { padding: 1rem 1.25rem 0.75rem; border-bottom: 1px solid var(--border); }
    .pm-card-title-row { display: flex; align-items: center; gap: 0.6rem; }
    .pm-card-icon { font-size: 1rem; }
    .pm-card-icon--projects   { color: var(--accent-p); }
    .pm-card-icon--developers { color: var(--accent-d); }
    .pm-card-icon--workitems  { color: var(--accent-w); }
    .pm-card-title {
        font-size: 0.9rem; font-weight: 700; letter-spacing: 0.04em;
        text-transform: uppercase; color: var(--text); flex: 1;
    }
    .pm-badge {
        font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-sub);
        background: var(--bg); border: 1px solid var(--border);
        border-radius: 100px; padding: 1px 8px;
    }
    .pm-card-body { padding: 0.75rem; flex: 1; overflow-y: auto; max-height: 340px; }
    .pm-card--wide .pm-card-body { max-height: 400px; }

    .pm-empty {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; padding: 2.5rem; gap: 0.5rem;
        color: var(--text-muted); font-family: var(--font-mono);
        font-size: 0.78rem; text-align: center;
    }
    .pm-empty-icon { font-size: 1.5rem; opacity: 0.3; }

    .pm-list { display: flex; flex-direction: column; gap: 2px; }
    .pm-list-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.6rem 0.75rem; border-radius: var(--radius);
        border: 1px solid transparent;
        transition: background 0.15s, border-color 0.15s;
    }
    .pm-list-item:hover { background: var(--bg-hover); border-color: var(--border-light); }
    .pm-list-item--clickable { cursor: pointer; }
    .pm-list-item-accent { width: 3px; height: 32px; border-radius: 2px; flex-shrink: 0; }
    .pm-list-item-accent--projects   { background: var(--accent-p); }
    .pm-list-item-accent--developers { background: var(--accent-d); }
    .pm-list-item-content { flex: 1; min-width: 0; }
    .pm-item-pills { display: flex; flex-direction: column; gap: 3px; align-items: flex-end; flex-shrink: 0; }

    .pm-item-name { display: block; font-size: 0.875rem; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pm-item-sub  { display: block; font-size: 0.72rem; color: var(--text-sub); font-family: var(--font-mono); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pm-item-id   { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-muted); }

    .pm-avatar {
        width: 32px; height: 32px;
        background: linear-gradient(135deg, var(--accent-d), var(--accent-p));
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-size: 0.65rem; font-weight: 700; color: #0d0f12; flex-shrink: 0;
    }
    .pm-avatar--sm  { width: 22px; height: 22px; font-size: 0.55rem; }
    .pm-avatar--img { object-fit: cover; }
    .pm-assignee { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text); }

    .pm-pill {
        font-family: var(--font-mono); font-size: 0.6rem; font-weight: 500;
        padding: 2px 6px; border-radius: 100px; border: 1px solid;
        white-space: nowrap; text-transform: uppercase; letter-spacing: 0.03em;
    }

    .pm-pill--priority-priority    { color: #f87171; border-color: #4a1515; background: #1c0808; }
    .pm-pill--priority-notpriority { color: var(--text-sub); border-color: var(--border); background: var(--bg); }

    .pm-pill--activity-high     { color: var(--accent-p); border-color: #1e3a5f; background: #0c1929; }
    .pm-pill--activity-moderate { color: var(--accent-w); border-color: #4a2d00; background: #1c1000; }
    .pm-pill--activity-low      { color: var(--text-sub); border-color: var(--border); background: var(--bg); }

    .pm-pill--workload-standby     { color: var(--text-sub);  border-color: var(--border);  background: var(--bg); }
    .pm-pill--workload-underloaded { color: var(--accent-d);  border-color: #064e3b;        background: #022c22; }
    .pm-pill--workload-balanced    { color: var(--accent-p);  border-color: #1e3a5f;        background: #0c1929; }
    .pm-pill--workload-overloaded  { color: var(--danger);    border-color: #4a1515;        background: #1c0808; }

    .pm-pill--health-healthy   { color: var(--accent-d); border-color: #064e3b; background: #022c22; }
    .pm-pill--health-unhealthy { color: var(--danger);   border-color: #4a1515; background: #1c0808; }

    .pm-table-wrap { overflow-x: auto; }
    .pm-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .pm-table thead th {
        text-align: left; font-family: var(--font-mono); font-size: 0.68rem;
        text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-sub);
        padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); white-space: nowrap;
    }
    .pm-table-row td { padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    .pm-table-row:last-child td { border-bottom: none; }
    .pm-table-row:hover td { background: var(--bg-hover); }
    .pm-table-row--clickable { cursor: pointer; }
    .pm-table-expand-row td { padding: 0; background: var(--bg-hover); }

    .pm-status-pill {
        font-family: var(--font-mono); font-size: 0.65rem; font-weight: 500;
        padding: 2px 8px; border-radius: 100px; border: 1px solid;
        white-space: nowrap; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .pm-status-pill--investigating { color: var(--accent-w); border-color: #4a2d00; background: #1c1000; }
    .pm-status-pill--implementing  { color: var(--accent-p); border-color: #1e3a5f; background: #0c1929; }
    .pm-status-pill--waiting       { color: #c084fc;         border-color: #3b1f6e; background: #160d2c; }
    .pm-status-pill--dev-deployed  { color: #60a5fa;         border-color: #1e3a5f; background: #0c1929; }
    .pm-status-pill--uat-deployed  { color: #fb923c;         border-color: #4a2200; background: #1c0d00; }
    .pm-status-pill--prod-deployed { color: var(--accent-d); border-color: #064e3b; background: #022c22; }
    .pm-status-pill--unknown       { color: var(--text-sub); border-color: var(--border); background: var(--bg); }

    .pm-expand-chevron {
        font-size: 18px; color: var(--text-sub);
        transition: transform 0.2s; display: inline-block;
        margin-left: auto; padding-left: 8px; flex-shrink: 0;
    }
    .pm-expand-chevron--open { transform: rotate(90deg); }

    .pm-expand-panel {
        padding: 10px 16px 12px 24px;
        border-left: 2px solid var(--border-light);
        margin: 0 0 4px 16px;
        display: flex; flex-direction: column; gap: 6px;
    }
    .pm-expand-panel--table {
        margin: 0; border-left: none;
        border-top: 1px dashed var(--border-light);
        padding: 12px 16px;
    }
    .pm-expand-row { display: flex; align-items: center; gap: 10px; font-size: 13px; }
    .pm-expand-row--top { align-items: flex-start; }
    .pm-expand-label { min-width: 80px; color: var(--text-sub); font-size: 12px; font-family: var(--font-mono); }
    .pm-expand-tags { display: flex; flex-wrap: wrap; gap: 4px; }
    .pm-tag {
        font-size: 11px; padding: 2px 8px; border-radius: 4px;
        background: var(--bg); border: 1px solid var(--border);
        color: var(--text-sub); font-family: var(--font-mono);
    }
    .pm-link { color: var(--accent-p); text-decoration: none; font-size: 13px; word-break: break-all; }
    .pm-link:hover { text-decoration: underline; }

    .pm-float {
        position: fixed; bottom: 1.75rem; right: 1.75rem; z-index: 100;
        display: flex; align-items: center; gap: 0.5rem;
        background: var(--accent-p); color: #fff;
        border: none; border-radius: 50px;
        padding: 0.75rem 1.25rem 0.75rem 1rem;
        font-family: var(--font-display); font-size: 0.85rem; font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 24px rgba(79, 142, 247, 0.35);
        transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
        user-select: none;
    }
    .pm-float:hover  { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(79, 142, 247, 0.45); }
    .pm-float:active { transform: scale(0.97); }
    .pm-float--open  { background: #374151; box-shadow: 0 4px 16px rgba(0,0,0,0.4); }
    .pm-float-icon   { font-size: 1.1rem; line-height: 1; }
    .pm-float-label  { font-size: 0.82rem; }

    @@media (max-width: 480px) {
        .pm-float { bottom: 1.25rem; right: 1.25rem; padding: 0.85rem; border-radius: 50%; }
        .pm-float-label { display: none; }
    }

    .pm-modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.65); backdrop-filter: blur(4px);
        z-index: 200; display: flex;
        align-items: flex-end; justify-content: flex-end;
        padding: 0 1.75rem 5.5rem;
    }
    @@media (max-width: 600px) {
        .pm-modal-backdrop { justify-content: stretch; padding: 0 0 5rem; }
    }
    .pm-modal {
        background: var(--bg-card); border: 1px solid var(--border-light);
        border-radius: var(--radius-lg); width: 420px; max-width: 100%;
        max-height: 85vh; display: flex; flex-direction: column;
        box-shadow: 0 24px 64px rgba(0,0,0,0.6);
        animation: modal-in 0.2s ease;
    }
    @@media (max-width: 600px) {
        .pm-modal { width: 100%; border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
    }
    @@keyframes modal-in {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .pm-modal-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); flex-shrink: 0;
    }
    .pm-modal-title { font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
    .pm-modal-close {
        background: none; border: none; cursor: pointer; color: var(--text-sub);
        font-size: 1rem; padding: 4px 8px; border-radius: var(--radius);
        transition: background 0.15s, color 0.15s;
    }
    .pm-modal-close:hover { background: var(--bg-hover); color: var(--text); }

    .pm-modal-tabs { display: flex; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .pm-tab {
        flex: 1; background: none; border: none; cursor: pointer;
        padding: 0.7rem 0.5rem; font-family: var(--font-display);
        font-size: 0.75rem; font-weight: 600; color: var(--text-sub);
        display: flex; align-items: center; justify-content: center; gap: 0.35rem;
        border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
        text-transform: uppercase; letter-spacing: 0.03em;
    }
    .pm-tab:hover   { color: var(--text); }
    .pm-tab--active { color: var(--text); border-bottom-color: var(--accent-p); }
    .pm-tab-icon    { font-size: 0.9rem; }
    .pm-modal-body  { padding: 1.25rem; overflow-y: auto; flex: 1; }

    .pm-alert { padding: 0.6rem 0.875rem; border-radius: var(--radius); font-size: 0.8rem; font-family: var(--font-mono); margin-bottom: 1rem; }
    .pm-alert--success { background: #022c22; border: 1px solid #064e3b; color: var(--success); }
    .pm-alert--error   { background: #1c0808; border: 1px solid #4a1515; color: var(--danger); }

    .pm-form-mode-toggle { display: flex; gap: 0.5rem; margin-bottom: 1.25rem; }
    .pm-mode-btn {
        flex: 1; background: var(--bg); border: 1px solid var(--border);
        border-radius: var(--radius); color: var(--text-sub);
        font-family: var(--font-display); font-size: 0.78rem; font-weight: 600;
        padding: 0.5rem; cursor: pointer;
        transition: all 0.15s; text-transform: uppercase; letter-spacing: 0.03em;
    }
    .pm-mode-btn.active             { background: var(--bg-hover); border-color: var(--accent-p); color: var(--text); }
    .pm-mode-btn:hover:not(.active) { border-color: var(--border-light); color: var(--text); }

    .pm-form      { display: flex; flex-direction: column; gap: 0.875rem; }
    .pm-field     { display: flex; flex-direction: column; gap: 0.35rem; }
    .pm-field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
    .pm-label     { font-size: 0.72rem; font-weight: 600; color: var(--text-sub); text-transform: uppercase; letter-spacing: 0.05em; }
    .pm-required  { color: var(--danger); }

    .pm-input {
        background: var(--bg-input); border: 1px solid var(--border);
        border-radius: var(--radius); color: var(--text);
        font-family: var(--font-display); font-size: 0.85rem;
        padding: 0.55rem 0.75rem; outline: none;
        transition: border-color 0.15s; width: 100%;
    }
    .pm-input:focus        { border-color: var(--accent-p); }
    .pm-input::placeholder { color: var(--text-muted); }
    .pm-input--mono        { font-family: var(--font-mono); }
    .pm-select             { cursor: pointer; }
    .pm-select option      { background: var(--bg-card); }
    .pm-select--multi      { height: auto; min-height: 100px; padding: 0.25rem; }

    .pm-btn {
        padding: 0.65rem 1.25rem; border: none; border-radius: var(--radius);
        font-family: var(--font-display); font-size: 0.82rem; font-weight: 700;
        cursor: pointer; text-transform: uppercase; letter-spacing: 0.04em;
        transition: opacity 0.15s, transform 0.1s; margin-top: 0.25rem;
    }
    .pm-btn:hover    { opacity: 0.88; }
    .pm-btn:active   { transform: scale(0.98); }
    .pm-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .pm-btn--primary   { background: var(--accent-p); color: #fff; }
    .pm-btn--secondary { background: var(--bg-hover); color: var(--text); border: 1px solid var(--border-light); }

    #blazor-error-ui {
        display: none; position: fixed; bottom: 0; left: 0; right: 0;
        background: #1c0808; border-top: 1px solid #4a1515; color: var(--danger);
        font-size: 0.8rem; padding: 0.75rem 1rem; z-index: 9999; font-family: var(--font-mono);
    }
    #blazor-error-ui .reload  { color: var(--accent-p); margin-left: 0.5rem; }
    #blazor-error-ui .dismiss { cursor: pointer; float: right; }
</style>